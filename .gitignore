# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Expo tooling scratch (route checks, type refresh, etc.)
.expo-*/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS / Windows
.DS_Store
Thumbs.db
*.pem

# env & secrets — never commit these
.env
.env.*
!.env.example
supabase/.env
supabase/.env.*

# Supabase CLI local state
supabase/.temp/
supabase/.branches/

# Vercel local project link
.vercel/

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# editor / local tooling
.idea/
.vscode/
.cursor/
.claude/
